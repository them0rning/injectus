<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>title</key>
    <string>CamSpoof</string>
    <key>items</key>
    <array>

        <!-- Enable toggle -->
        <dict>
            <key>cell</key>    <string>PSGroupCell</string>
        </dict>
        <dict>
            <key>cell</key>    <string>PSSwitchCell</string>
            <key>label</key>   <string>Enable CamSpoof</string>
            <key>key</key>     <string>enabled</string>
            <key>default</key> <false/>
            <key>defaults</key><string>com.yourname.camspoof</string>
            <key>PostNotification</key>
            <string>com.yourname.camspoof/settingsChanged</string>
        </dict>

        <!-- Photo actions -->
        <dict>
            <key>cell</key>    <string>PSGroupCell</string>
            <key>label</key>   <string>Fake Photo</string>
        </dict>
        <dict>
            <key>cell</key>   <string>PSButtonCell</string>
            <key>label</key>  <string>Choose Photo…</string>
            <key>action</key> <string>choosePhoto</string>
        </dict>
        <dict>
            <key>cell</key>   <string>PSButtonCell</string>
            <key>label</key>  <string>Clear Photo</string>
            <key>action</key> <string>clearPhoto</string>
        </dict>

    </array>
</dict>
</plist>
